---
// Sebastian Balderrama - Portfolio Homepage
// index.astro
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sebastian Balderrama - Software Engineer portfolio." />
    <title>Sebastian Balderrama - Software Engineer</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

    <style>
      * { box-sizing: border-box; }

      body {
        background-color: #080c0f;
        color: #e8edf2;
        font-family: 'DM Sans', sans-serif;
      }

      /* Noise texture overlay */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 0;
        opacity: 0.5;
      }

      /* Dot grid */
      .dot-grid {
        background-image: radial-gradient(circle, #1e2a35 1px, transparent 1px);
        background-size: 28px 28px;
      }

      /* Stagger delays */
      .delay-100 { animation-delay: 0.1s; }
      .delay-200 { animation-delay: 0.2s; }
      .delay-300 { animation-delay: 0.3s; }
      .delay-400 { animation-delay: 0.4s; }
      .delay-500 { animation-delay: 0.5s; }
      .delay-600 { animation-delay: 0.6s; }
      .delay-700 { animation-delay: 0.7s; }

      .opacity-0-init { opacity: 0; }

      /* Nav blur */
      .nav-glass {
        background: rgba(8, 12, 15, 0.75);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border-bottom: 1px solid rgba(30, 42, 53, 0.6);
      }

      /* Gradient text */
      .grad-text {
        background: linear-gradient(135deg, #e8edf2 0%, #22d3ee 60%, #06b6d4 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      /* Glow */
      .cyan-glow {
        box-shadow: 0 0 24px rgba(34, 211, 238, 0.18), 0 0 64px rgba(34, 211, 238, 0.06);
      }

      /* Card hover */
      .project-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
      }
      .project-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 20px 48px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(34, 211, 238, 0.2);
        border-color: rgba(34, 211, 238, 0.3);
      }

      /* Nav links */
      .nav-link {
        position: relative;
        transition: color 0.2s ease;
      }
      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        width: 0;
        height: 1px;
        background: #22d3ee;
        transition: width 0.25s ease;
      }
      .nav-link:hover::after { width: 100%; }
      .nav-link:hover { color: #22d3ee; }

      /* Skill tags */
      .skill-tag {
        transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease;
      }
      .skill-tag:hover {
        background: rgba(34, 211, 238, 0.1);
        border-color: rgba(34, 211, 238, 0.4);
        color: #22d3ee;
      }

      /* Buttons */
      .btn-primary {
        transition: box-shadow 0.25s ease, transform 0.2s ease, background 0.2s ease;
      }
      .btn-primary:hover {
        box-shadow: 0 0 28px rgba(34, 211, 238, 0.35);
        transform: translateY(-1px);
      }
      .btn-secondary {
        transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
      }
      .btn-secondary:hover {
        border-color: #22d3ee;
        color: #22d3ee;
        transform: translateY(-1px);
      }

      /* Social links */
      .social-link {
        transition: color 0.2s ease, transform 0.2s ease;
      }
      .social-link:hover {
        color: #22d3ee;
        transform: translateY(-2px);
      }

      /* Orb */
      .orb {
        border-radius: 50%;
        filter: blur(80px);
        animation: float 6s ease-in-out infinite;
      }

      /* Section scroll reveal */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition: opacity 0.7s ease, transform 0.7s ease;
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Mobile menu */
      #mobile-menu {
        max-height: 0;
        transition: max-height 0.35s ease, opacity 0.3s ease;
      }
      #mobile-menu.mobile-menu-open {
        max-height: 12rem;
      }

      /* Scrollbar */
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: #080c0f; }
      ::-webkit-scrollbar-thumb { background: #1e2a35; border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: #22d3ee44; }
    </style>
  </head>

  <body class="relative overflow-x-hidden">

    <!-- NAV -->
    <header class="nav-glass fixed top-0 left-0 right-0 z-50">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <span class="font-mono text-xs text-cyan-400 opacity-60 group-hover:opacity-100 transition-opacity">&lt;</span>
          <span class="font-display text-lg text-text-primary tracking-wide">Sebastian Balderrama</span>
          <span class="font-mono text-xs text-cyan-400 opacity-60 group-hover:opacity-100 transition-opacity">/&gt;</span>
        </a>

        <!-- Desktop Links -->
        <ul class="hidden md:flex items-center gap-8">
          {['Home', 'Projects', 'About', 'Contact'].map((item) => (
            <li>
              <a
                href={item === 'Home' ? '#' : `#${item.toLowerCase()}`}
                class="nav-link font-mono text-xs text-text-muted tracking-widest uppercase"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden flex flex-col gap-1.5 p-2 group"
          aria-label="Toggle menu"
        >
          <span class="w-5 h-px bg-text-muted group-hover:bg-cyan-400 transition-colors block"></span>
          <span class="w-3.5 h-px bg-text-muted group-hover:bg-cyan-400 transition-colors block"></span>
          <span class="w-5 h-px bg-text-muted group-hover:bg-cyan-400 transition-colors block"></span>
        </button>
      </nav>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="md:hidden overflow-hidden border-t border-border">
        <ul class="flex flex-col px-6 py-4 gap-4">
          {['Home', 'Projects', 'About', 'Contact'].map((item) => (
            <li>
              <a
                href={item === 'Home' ? '#' : `#${item.toLowerCase()}`}
                class="font-mono text-xs text-text-muted tracking-widest uppercase hover:text-cyan-400 transition-colors"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>


    <!-- HERO -->
    <section class="relative min-h-screen flex items-center dot-grid pt-16">

      <!-- Background orbs -->
      <div class="absolute top-24 right-8 w-80 h-80 orb bg-cyan-500 opacity-[0.06] pointer-events-none"></div>
      <div class="absolute bottom-24 left-[-80px] w-64 h-64 orb bg-cyan-400 opacity-[0.04] pointer-events-none" style="animation-delay: 3s;"></div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">

        <!-- Left -->
        <div class="space-y-8">
          <div class="opacity-0-init animate-fade-up">
            <span class="font-mono text-xs text-cyan-400 tracking-[0.2em] uppercase">
              ? Available for opportunities
            </span>
          </div>

          <h1 class="opacity-0-init animate-fade-up delay-100 font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight">
            Hi, I'm <br />
            <span class="grad-text">Sebastian</span>
            <span class="text-text-muted"> -</span>
            <br />
            Software Engineer
          </h1>

          <p class="opacity-0-init animate-fade-up delay-200 font-sans text-base text-text-muted leading-relaxed max-w-md">
            Computer Science &amp; Mathematics graduate building software, machine learning projects, and web applications. I turn complex problems into elegant solutions.
          </p>

          <div class="opacity-0-init animate-fade-up delay-300 flex flex-wrap gap-4">
            <a
              href="#projects"
              class="btn-primary inline-flex items-center gap-2 bg-cyan-500 text-bg font-sans font-semibold text-sm px-6 py-3 rounded-full cyan-glow"
            >
              View Projects
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="#contact"
              class="btn-secondary inline-flex items-center gap-2 border border-border text-text-muted font-sans text-sm px-6 py-3 rounded-full"
            >
              Contact Me
            </a>
          </div>

          <!-- Mini stats -->
          <div class="opacity-0-init animate-fade-up delay-400 flex gap-8 pt-4 border-t border-border">
            {[
              { value: '3+', label: 'Years Coding' },
              { value: '10+', label: 'Projects Built' },
              { value: '2', label: 'Degrees' },
            ].map((stat) => (
              <div>
                <div class="font-display text-2xl text-text-primary">{stat.value}</div>
                <div class="font-mono text-xs text-text-muted mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right - abstract visual -->
        <div class="opacity-0-init animate-fade-in delay-500 hidden md:flex items-center justify-center">
          <div class="relative w-80 h-80">

            <!-- Rotating ring -->
            <div class="absolute inset-0 rounded-full border border-dashed border-border animate-spin-slow"></div>
            <div class="absolute inset-6 rounded-full border border-dashed border-cyan-400 border-opacity-20 animate-spin-slow" style="animation-direction: reverse; animation-duration: 12s;"></div>

            <!-- Center card -->
            <div class="absolute inset-12 rounded-2xl bg-surface border border-border flex flex-col items-center justify-center gap-3 p-6">
              <!-- Code icon -->
              <div class="w-12 h-12 rounded-xl bg-cyan-500 bg-opacity-10 border border-cyan-400 border-opacity-20 flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                </svg>
              </div>
              <div class="text-center">
                <p class="font-mono text-xs text-cyan-400">~/portfolio</p>
                <p class="font-mono text-xs text-text-muted mt-0.5">v1.0.0</p>
              </div>
              <!-- Stack dots -->
              <div class="flex gap-1.5">
                <span class="w-2 h-2 rounded-full bg-cyan-400 opacity-80"></span>
                <span class="w-2 h-2 rounded-full bg-amber-400 opacity-60"></span>
                <span class="w-2 h-2 rounded-full bg-text-faint"></span>
              </div>
            </div>

            <!-- Floating corner badges -->
            <div class="absolute -top-3 -right-3 bg-surface border border-border rounded-lg px-3 py-1.5 font-mono text-xs text-cyan-400 animate-float">
              ML
            </div>
            <div class="absolute -bottom-3 -left-3 bg-surface border border-border rounded-lg px-3 py-1.5 font-mono text-xs text-amber-400 animate-float" style="animation-delay: 2s;">
              CS + Math
            </div>
          </div>
        </div>

      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 animate-fade-in delay-700">
        <span class="font-mono text-xs text-text-muted tracking-widest">SCROLL</span>
        <div class="w-px h-8 bg-gradient-to-b from-text-muted to-transparent"></div>
      </div>
    </section>


    <!-- ABOUT -->
    <section id="about" class="relative py-28">
      <div class="max-w-6xl mx-auto px-6">

        <div class="reveal grid md:grid-cols-[1fr_1.4fr] gap-16 items-start">

          <!-- Left label -->
          <div class="space-y-6">
            <div>
              <span class="font-mono text-xs text-cyan-400 tracking-widest uppercase">02 - About</span>
              <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">
                About <em>Me</em>
              </h2>
            </div>

            <!-- Decorative line -->
            <div class="flex items-center gap-3">
              <div class="w-8 h-px bg-cyan-400 opacity-60"></div>
              <div class="w-2 h-2 rounded-full border border-cyan-400 opacity-40"></div>
            </div>
          </div>

          <!-- Right content -->
          <div class="space-y-8">
            <div class="space-y-5 text-text-muted leading-relaxed font-sans text-[15px]">
              <p>
                I'm a Computer Science and Mathematics graduate with a genuine love for building things that matter. From training machine learning models to crafting responsive web applications, I enjoy the full spectrum of software engineering.
              </p>
              <p>
                My academic background gives me a strong foundation in algorithms, statistics, and mathematical reasoning - skills I apply daily when designing systems and solving real-world problems. I'm particularly drawn to the intersection of data and software.
              </p>
              <p>
                When I'm not coding, I'm exploring new research in machine learning, contributing to open-source, or finding ways to make data tell clearer stories.
              </p>
            </div>

            <!-- Skills grid -->
            <div class="space-y-3">
              <p class="font-mono text-xs text-text-muted tracking-widest uppercase">Tech Stack</p>
              <div class="flex flex-wrap gap-2">
                {[
                  'Python', 'Java', 'TypeScript', 'React',
                  'SQL', 'Machine Learning', 'R', 'C',
                  'Astro', 'Node.js', 'Git', 'TailwindCSS',
                ].map((skill) => (
                  <span class="skill-tag font-mono text-xs text-text-muted border border-border px-3 py-1.5 rounded-full bg-surface cursor-default">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- PROJECTS -->
    <section id="projects" class="relative py-28 bg-surface bg-opacity-40">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Header -->
        <div class="reveal flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
          <div>
            <span class="font-mono text-xs text-cyan-400 tracking-widest uppercase">03 - Work</span>
            <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">Featured Projects</h2>
          </div>
          <a href="#" class="font-mono text-xs text-text-muted hover:text-cyan-400 transition-colors tracking-wider group flex items-center gap-2 self-start sm:self-auto">
            View all
            <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Cards grid -->
        <div class="reveal grid md:grid-cols-3 gap-6">

          <!-- Card 1 -->
          <article class="project-card bg-surface border border-border rounded-2xl p-6 flex flex-col gap-5">
            <div class="flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-cyan-500 bg-opacity-10 border border-cyan-400 border-opacity-20 flex items-center justify-center">
                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                </svg>
              </div>
              <span class="font-mono text-xs text-text-faint">01</span>
            </div>

            <div class="space-y-2 flex-1">
              <h3 class="font-display text-xl text-text-primary">Alzheimer's Prediction</h3>
              <p class="font-sans text-sm text-text-muted leading-relaxed">
                A machine learning pipeline that predicts early-stage Alzheimer's disease from clinical and neuroimaging features, achieving over 90% classification accuracy.
              </p>
            </div>

            <div class="flex flex-wrap gap-1.5">
              {['Python', 'scikit-learn', 'Pandas', 'Jupyter'].map((t) => (
                <span class="font-mono text-xs text-text-muted bg-bg border border-border px-2 py-0.5 rounded-full">{t}</span>
              ))}
            </div>

            <a href="#" class="inline-flex items-center gap-2 font-mono text-xs text-text-muted hover:text-cyan-400 transition-colors group">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
              GitHub ?
              <span class="w-0 group-hover:w-2 overflow-hidden transition-all duration-200">_</span>
            </a>
          </article>

          <!-- Card 2 -->
          <article class="project-card bg-surface border border-border rounded-2xl p-6 flex flex-col gap-5">
            <div class="flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-amber-400 bg-opacity-10 border border-amber-400 border-opacity-20 flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />
                </svg>
              </div>
              <span class="font-mono text-xs text-text-faint">02</span>
            </div>

            <div class="space-y-2 flex-1">
              <h3 class="font-display text-xl text-text-primary">NLP Web Application</h3>
              <p class="font-sans text-sm text-text-muted leading-relaxed">
                A full-stack web application that processes natural language queries, performs sentiment analysis, and returns structured insights via a clean REST API.
              </p>
            </div>

            <div class="flex flex-wrap gap-1.5">
              {['Java', 'Spring Boot', 'NLP', 'REST API'].map((t) => (
                <span class="font-mono text-xs text-text-muted bg-bg border border-border px-2 py-0.5 rounded-full">{t}</span>
              ))}
            </div>

            <a href="#" class="inline-flex items-center gap-2 font-mono text-xs text-text-muted hover:text-cyan-400 transition-colors group">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
              </svg>
              GitHub ?
              <span class="w-0 group-hover:w-2 overflow-hidden transition-all duration-200">_</span>
            </a>
          </article>

          <!-- Card 3 -->
          <article class="project-card bg-surface border border-border rounded-2xl p-6 flex flex-col gap-5">
            <div class="flex items-start justify-between">
              <div class="w-10 h-10 rounded-xl bg-cyan-500 bg-opacity-10 border border-cyan-400 border-opacity-20 flex items-center justify-center">
                <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
