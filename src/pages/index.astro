---
// Sebastian Balderrama - Portfolio Homepage
// index.astro
import { Image } from 'astro:assets';
import '../styles/global.css';
import '../styles/index.css';
import ProfileCard from '../../components/ProfileCard';

import fitquestImage from '../images/fitquest1thumb.png';
import mapleImage from '../images/maple.png';
import voicecloneImage from '../images/voiceclone.png';
import simrcvImage from '../images/simrcv.png';
import wearaboutsImage from '../images/wearabouts.png';

const projects = [
  {
  title: 'WEAR_ABOUTS',
  description: 'A full-stack peer-to-peer clothing marketplace for buying and renting nearby pieces, featuring AI style search, outfit generation, photo enhancement, and an interactive map.',
  techStack: ['React', 'TS', 'Node', 'MongoDB Atlas','Cloudinary', 'Backboard.io'],
  githubLink: 'https://github.com/SeBalderrama/HackCanada-2026',
  liveDemo: 'https://devpost.com/software/wear-abouts',
  image: wearaboutsImage,
  hackathon: 'Hack Canada 2026 SPUR Top 10',
  },
  {
    title: 'FitQuest',
    description: 'An AI-powered fitness game that makes workouts fun, blending: AI Coach, Nutritionist AI, Real-Time Form Analysis, and RPG Progression.',
    techStack: ['React', 'Node.js', 'MongoDB', 'Railway', 'Express', 'Gemini'],
    githubLink: 'https://github.com/AhmadYahya-05/AlgorithmAthletes',
    liveDemo: 'https://devpost.com/software/fitness-quest-31h2ci',
    image: fitquestImage,
    hackathon: 'SpurHacks 2025 2nd Place',
  },
  {
    title: 'Canify',
    description: 'A Google Chrome extension that analyzes the items in your Amazon cart, assessing them based on whether they are Canadian-made, ethically sourced, and provide good value for money.',
    techStack: ['JavaScript', 'Tailwind CSS', 'Flask', 'Rust', 'NEAR Shade Agents', 'Gemini'],
    githubLink: 'https://github.com/MBA380/Canify',
    liveDemo: 'https://dorahacks.io/buidl/23018/',
    image: mapleImage,
    hackathon: 'Hack Canada 2025 Finalist',
  },
  {
    title: 'Voice Clone',
    description: "A Voice Clone of myself using Sesame's Conversational Speech Model (CSM). Transcription through FasterWhisper, Tokenizing with HuggingFace, Training through Collab, etc.",
    techStack: ['Python', 'HuggingFace', 'Google Collab', 'FasterWhisper', 'Sesame', 'OpenAI'],
    image: voicecloneImage,
  },
  {
    title: 'Simulating RCV',
    description: 'Exploring the potential outcomes of implementing ranked choice voting (RCV) systems: Instant Runoff Voting (IRV), Borda Count, and Defeat-Dropping Condorcet (DDC) in the 2021 Canadian federal election through Monte Carlo simulations.',
    techStack: ['Monte Carlo Simulations', 'Pandas', 'Numpy'],
    image: simrcvImage,
  },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Sebastian Balderrama - Software Engineer portfolio." />
    <title>Sebastian Balderrama - Software Engineer</title>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Serif+Display:ital@0;1&family=JetBrains+Mono:wght@400;500;700&family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />

  </head>

  <body class="relative overflow-x-hidden">
    <!-- Vanta.js NET background (full viewport, behind all content) -->
    <div id="vanta-bg" aria-hidden="true"></div>

    <!-- Content scrim: dark overlay so text stays readable over Vanta -->
    <div id="vanta-scrim" class="vanta-scrim" aria-hidden="true"></div>

    <!-- Main content (above scrim) -->
    <div class="relative z-10">
    <!-- NAV -->
    <header class="nav-glass fixed top-0 left-0 right-0 z-50">
      <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a href="#" class="flex items-center gap-2 group">
          <span class="font-mono text-xs text-green-400 opacity-60 group-hover:opacity-100 transition-opacity">&lt;</span>
          <span class="font-display text-lg text-text-primary tracking-wide">Sebastian Balderrama</span>
          <span class="font-mono text-xs text-green-400 opacity-60 group-hover:opacity-100 transition-opacity">/&gt;</span>
        </a>

        <!-- Desktop Links -->
        <ul class="hidden md:flex items-center gap-8">
          {['Home', 'Projects', 'Experience', 'About', 'Contact'].map((item) => (
            <li>
              <a
                href={item === 'Home' ? '#' : `#${item.toLowerCase()}`}
                class="nav-link font-mono text-xs text-text-muted tracking-widest uppercase"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>

        <!-- Mobile hamburger -->
        <button
          id="menu-btn"
          class="md:hidden flex flex-col gap-1.5 p-2 group"
          aria-label="Toggle menu"
        >
          <span class="w-5 h-px bg-text-muted group-hover:bg-green-400 transition-colors block"></span>
          <span class="w-3.5 h-px bg-text-muted group-hover:bg-green-400 transition-colors block"></span>
          <span class="w-5 h-px bg-text-muted group-hover:bg-green-400 transition-colors block"></span>
        </button>
      </nav>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="md:hidden overflow-hidden border-t border-border">
        <ul class="flex flex-col px-6 py-4 gap-4">
          {['Home', 'Projects', 'Experience', 'About', 'Contact'].map((item) => (
            <li>
              <a
                href={item === 'Home' ? '#' : `#${item.toLowerCase()}`}
                class="font-mono text-xs text-text-muted tracking-widest uppercase hover:text-green-400 transition-colors"
              >
                {item}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </header>


    <!-- HERO -->
    <section class="relative min-h-screen flex items-center pt-16">

      <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-2 gap-12 items-center">

        <!-- Left -->
        <div class="space-y-8">
          <div class="opacity-0-init animate-fade-up">
            <span class="font-mono text-xs text-green-400 tracking-[0.2em] uppercase">
              ? Available for opportunities
            </span>
          </div>

          <h1 class="opacity-0-init animate-fade-up delay-100 font-display text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight">
            
            <span class="grad-text">Sebastian Balderrama</span>
            <span class="text-text-muted"> -</span>
            <br/>
            <span class="block mt-1 text-xl sm:text-2xl font-sans font-normal text-text-muted">Software Engineer</span>
          </h1>

          <p class="opacity-0-init animate-fade-up delay-200 font-sans text-base text-text-muted leading-relaxed max-w-md">
            I turn simple problems into complex solutions. 
            <br/>Wait, that doesn't sound right...
          </p>

          <div class="opacity-0-init animate-fade-up delay-300 flex flex-wrap gap-4 items-center">
            <a
              href="#projects"
              class="button-49"
              role="button"
            >
              View Projects
            </a>
            <a
              href="#contact"
              class="btn-secondary inline-flex items-center gap-2 border border-border text-text-muted font-sans text-sm px-6 py-3 rounded-full"
            >
              Contact Me
            </a>
          </div>

          <!-- Mini stats -->
          <div class="opacity-0-init animate-fade-up delay-400 flex gap-8 pt-4 border-t border-border">
            {[
              { value: '5+', label: 'Projects Built' },
              { value: '3/3', label: 'Hackathons Won' },
            ].map((stat) => (
              <div>
                <div class="font-display text-2xl text-text-primary">{stat.value}</div>
                <div class="font-mono text-xs text-text-muted mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right - abstract visual -->
        <div class="opacity-0-init animate-fade-in delay-500 hidden md:flex items-center justify-center">
          <ProfileCard
            client:load
            avatarUrl="/cleanga1.png"
            eagerLoad={true}
            name="Sebastian Balderrama"
            title="Software Engineer"
            handle="portfolio"
            status="Available"
            contactText="Contact"
          />
        </div>

      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-40 animate-fade-in delay-700">
        <span class="font-mono text-xs text-text-muted tracking-widest">SCROLL</span>
        <div class="w-px h-8 bg-gradient-to-b from-text-muted to-transparent"></div>
      </div>
    </section>


    <!-- ABOUT -->
    <section id="about" class="relative py-28">
      <div class="max-w-6xl mx-auto px-6">

        <div class="reveal grid md:grid-cols-[1fr_1.4fr] gap-16 items-start">

          <!-- Left label -->
          <div class="space-y-6">
            <div>
              <span class="font-mono text-xs text-green-400 tracking-widest uppercase">02 - About</span>
              <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">
                About <em>Me</em>
              </h2>
            </div>

            <!-- Decorative line -->
            <div class="flex items-center gap-3">
              <div class="w-8 h-px bg-green-400 opacity-60"></div>
              <div class="w-2 h-2 rounded-full border border-green-400 opacity-40"></div>
            </div>
          </div>

          <!-- Right content -->
          <div class="space-y-8">
            <div class="space-y-5 text-text-muted leading-relaxed font-sans text-[15px]">
              <p>
                I'm a Software Dev in Waterloo with an Honours BSc in Computer Science & Mathematics @ Wilfrid Laurier University.
              </p>
              <p>
                I enjoy building systems end-to-end, with a strong focus on backend development and AI-powered systems. My experience spans backend services and databases using Python, Java, Node.js, and SQL, as well as full-stack development with React and modern JS frameworks (like Astro which this site is built with!). I've worked on projects involving cloud deployment, containerization, machine learning, computer vision, and speech models.
              </p>
              <p>
                Outside of coursework and professional work, I'm active in the Hackathon scene, recently placing Top 10 at Hack Canada 2026, 2nd at SpurHacks 2025, and Top 5 at Hack Canada 2025. I'm also part of the choir at my church, co-lead a Spanish tutoring club at UW, and (slowly) learning to play the guitar.
              </p>
              <p>
                Future: Self-hosting on an old craptop.
              </p>
            </div>

            <!-- Skills grid -->
            <div class="space-y-3">
              <p class="font-mono text-xs text-text-muted tracking-widest uppercase">Tech Stack</p>
              <div class="flex flex-wrap gap-2">
                {[
                  'Python', 'Java', 'TypeScript', 'React',
                  'SQL', 'Machine Learning', 'R', 'C',
                  'Astro', 'Node.js', 'Git', 'TailwindCSS', 'Auth0', 'Firebase'
                ].map((skill) => (
                  <span class="skill-tag font-mono text-xs text-text-muted border border-border px-3 py-1.5 rounded-full bg-surface cursor-default">
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- PROJECTS -->
    <section id="projects" class="relative py-28 bg-opacity-40">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Header -->
        <div class="reveal flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-14">
          <div>
            <span class="font-mono text-xs text-green-400 tracking-widest uppercase">03 - Work</span>
            <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">Featured Projects</h2>
          </div>
          <a href="https://github.com/SeBalderrama" class="font-mono text-xs text-text-muted hover:text-green-400 transition-colors tracking-wider group flex items-center gap-2 self-start sm:self-auto">
            View all
            <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Cards grid -->
        <div class="reveal grid md:grid-cols-3 gap-6">

          {projects.map((project, i) => (
            <article class="project-card bg-surface border border-border rounded-2xl p-6 flex flex-col gap-5">
              <div class="flex items-start justify-between gap-2">
                <div class="w-10 h-10 rounded-xl bg-green-500 bg-opacity-10 border border-green-400 border-opacity-20 flex items-center justify-center shrink-0">
                  <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
                  </svg>
                </div>
                <div class="flex items-center gap-2 min-w-0">
                  {project.hackathon && (
                    <span class="font-mono text-[10px] px-2 py-0.5 rounded-full bg-amber-500/20 text-amber-400 border border-amber-400/50 shrink-0">
                      {project.hackathon}
                    </span>
                  )}
                  <span class="font-mono text-xs text-text-faint shrink-0">{String(i + 1).padStart(2, '0')}</span>
                </div>
              </div>

              {project.image && (
                <div class="rounded-xl overflow-hidden bg-bg border border-border aspect-video flex items-center justify-center">
                  <Image src={project.image} alt={project.title} width={640} height={360} class="w-full h-full object-cover" />
                </div>
              )}

              <div class="space-y-2 flex-1">
                <h3 class="font-display text-xl text-text-primary">{project.title}</h3>
                <p class="font-sans text-sm text-text-muted leading-relaxed">
                  {project.description}
                </p>
              </div>

              <div class="flex flex-wrap gap-1.5">
                {project.techStack.map((t) => (
                  <span class="font-mono text-xs text-text-muted bg-bg border border-border px-2 py-0.5 rounded-full">{t}</span>
                ))}
              </div>

              <div class="flex flex-wrap items-center gap-3">
                {project.githubLink && (
                  <a href={project.githubLink} target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-mono text-xs text-text-muted hover:text-green-400 transition-colors group">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                    </svg>
                    GitHub
                    <span class="w-0 group-hover:w-2 overflow-hidden transition-all duration-200">_</span>
                  </a>
                )}
                {project.liveDemo && (
                  <a href={project.liveDemo} target="_blank" rel="noopener" class="inline-flex items-center gap-2 font-mono text-xs text-green-400 hover:opacity-80 transition-opacity group">
                    More
                    <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                )}
              </div>
            </article>
          ))}

        </div>
      </div>
    </section>

    <!-- ───────────────────────── EXPERIENCE ───────────────────────── -->
<section id="experience" class="relative py-28">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Header -->
    <div class="reveal mb-16">
      <span class="font-mono text-xs text-green-400 tracking-widest uppercase">04 — Experience</span>
      <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">Where I've Worked</h2>
    </div>

    <!-- Timeline -->
    <div class="reveal relative">

      <!-- Vertical line -->
      <div class="absolute left-0 md:left-[200px] top-0 bottom-0 w-px bg-gradient-to-b from-green-400 via-border to-transparent opacity-40 hidden sm:block"></div>

      <div class="flex flex-col gap-12">

        <!-- ── Internship 1 ── -->
        <div class="group relative sm:grid sm:grid-cols-[200px_1fr] gap-10 items-start">

          <!-- Date / company col -->
          <div class="sm:text-right sm:pr-10 mb-4 sm:mb-0">
            <span class="font-mono text-xs text-green-400 tracking-widest">May 2024 — Aug 2024</span>
            <p class="font-sans text-xs text-text-muted mt-1">Toronto, ON</p>
          </div>

          <!-- Dot on timeline -->
          <div class="absolute left-[-5px] md:left-[196px] top-1 w-2.5 h-2.5 rounded-full border-2 border-green-400 bg-bg hidden sm:block group-hover:bg-green-400 transition-colors duration-300"></div>

          <!-- Card -->
          <div class="project-card bg-surface border border-border rounded-2xl p-6 space-y-4 sm:ml-10">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="font-display text-xl text-text-primary">Software Engineering Intern</h3>
                <p class="font-sans text-sm text-green-400 mt-0.5">Veeva Systems</p>
              </div>
              <div class="w-9 h-9 shrink-0 rounded-xl bg-green-500 bg-opacity-10 border border-green-400 border-opacity-20 flex items-center justify-center">
                <svg class="w-4 h-4 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                </svg>
              </div>
            </div>

            <ul class="space-y-2">
              {[
                'Developed frontend and backend features for Veeva Vault as part of a small agile team operating on a four-week release cycle.',
                'Designed and implemented workflow enhancements including validation rules, concurrency improvements, and performance optimizations for high-traffic customer views.',
                'Wrote unit and integration tests achieving 90%+ code coverage across new modules.',
              ].map((point) => (
                <li class="flex items-start gap-2.5 font-sans text-sm text-text-muted leading-relaxed">
                  <span class="mt-1.5 w-1 h-1 rounded-full bg-green-400 opacity-60 shrink-0"></span>
                  {point}
                </li>
              ))}
            </ul>

            <div class="flex flex-wrap gap-1.5 pt-1">
              {['Python','React','TypeScript', 'Node.js', 'SQL'].map((t) => (
                <span class="font-mono text-xs text-text-muted bg-bg border border-border px-2 py-0.5 rounded-full">{t}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

    <!-- CONTACT -->
    <section id="contact" class="relative py-28 overflow-hidden">

      <div class="relative z-10 max-w-6xl mx-auto px-6">
        <div class="reveal max-w-2xl mx-auto text-center space-y-8">

          <div>
            <span class="font-mono text-xs text-green-400 tracking-widest uppercase">05 - Contact</span>
            <h2 class="font-display text-4xl lg:text-5xl mt-3 leading-tight">
              Let's Build Something
            </h2>
            <p class="font-sans text-text-muted text-[15px] leading-relaxed mt-4">
              Whether you have a project in mind, want to collaborate, or just want to say hello - my inbox is always open.
            </p>
          </div>

          <a
            href="mailto:sebastian.balderr@gmail.com"
            class="btn-primary inline-flex items-center gap-2 bg-green-500 text-bg font-sans font-semibold text-sm px-8 py-3.5 rounded-full green-glow"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
            </svg>
            Send a message
          </a>

          <!-- Social row -->
          <div class="flex items-center justify-center gap-8 pt-4 border-t border-border">

            <a href="mailto:sebastian.balderr@gmail.com" class="social-link flex flex-col items-center gap-2 text-text-muted group">
              <div class="w-10 h-10 rounded-xl border border-border bg-surface flex items-center justify-center group-hover:border-green-400 group-hover:border-opacity-40 transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
                </svg>
              </div>
              <span class="font-mono text-xs">Email</span>
            </a>

            <a href="https://github.com/SeBalderrama" target="_blank" rel="noopener" class="social-link flex flex-col items-center gap-2 text-text-muted group">
              <div class="w-10 h-10 rounded-xl border border-border bg-surface flex items-center justify-center group-hover:border-green-400 group-hover:border-opacity-40 transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
